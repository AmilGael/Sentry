# Database — PostgreSQL connection string
# For local development: postgresql://user:password@localhost:5432/reentry
# For Prisma dev server: npx prisma dev (auto-provisions)
DATABASE_URL="postgresql://user:password@localhost:5432/reentry"

# HMAC secret for cryptographic pass signing (256-bit / 32-byte key)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASS_SIGNING_SECRET="replace-with-a-64-char-hex-string"

# NextAuth.js / Auth.js (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-random-secret-minimum-32-chars"
AUTH_URL="http://localhost:3000"
